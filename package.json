{
  "name": "fuckia",
  "version": "0.1.0",
  "private": false,
  "description": "Claude and Codex collaboration guardrails for GitHub and Linear projects.",
  "type": "commonjs",
  "bin": {
    "fuckia": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "INSTALL.md",
    "kit"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node kit/scripts/build/create-cli-wrapper.mjs",
    "prepare": "npm run build",
    "check:skills": "npm run build && node dist/cli.js generate-skills --check",
    "generate-skills": "npm run build && node dist/cli.js generate-skills --write --examples",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "test:e2e": "npm run build && node kit/scripts/test/verify-installer.mjs",
    "fuckia": "node dist/cli.js"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED"
}
